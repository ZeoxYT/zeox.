{
  "version": 2,
  "rewrites": [
    {
      "source": "/raw/:filename",
      "destination": "/api?filename=:filename"
    }
  ],
  "headers": [
    {
      "source": "/raw/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control",          "value": "no-store"  }
      ]
    }
  ]
}
